# ─────────────────────────────────────────────────────────────
#  ExpertConnect Pro · Backend Environment Variables
# ─────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/expertconnect?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://harish:harish1234@cluster0.l7nztab.mongodb.net/expertconnect?retryWrites=true&w=majority&appName=Cluster0

# CORS — comma-separated list of allowed origins
CLIENT_URL=http://localhost:5173

# JWT (used for admin routes)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
